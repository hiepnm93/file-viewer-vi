{
  "name": "@flyfish-group/file-viewer3",
  "version": "1.0.3",
  "private": false,
  "description": "基于Vue3+TypeScript+Vite实现的文件在线预览组件，此组件开源，请打赏任意金额即可获取仓库地址",
  "keywords": [
    "file-viewer",
    "vue3",
    "doc-preview"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "author": {
    "name": "Wangyu",
    "email": "wybaby168@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://git.flyfish.dev/flyfish-group/file-viewer.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check build-only",
    "build-lib": "run-p type-check build-lib-only",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write src/",
    "build-lib-only": "vite build --mode lib"
  },
  "main": "dist/index.umd.js",
  "module": "dist/index.mjs",
  "types": "dist/src/package/index.d.ts",
  "dependencies": {
    "@handsontable/vue3": "^14.1.0",
    "axios": "^1.6.7",
    "billboard.js": "^3.10.3",
    "d3": "^7.8.5",
    "dingbat-to-unicode": "^1.0.1",
    "docx-preview": "^0.3.0",
    "exceljs": "^4.4.0",
    "github-markdown-css": "^5.5.0",
    "handsontable": "^14.1.0",
    "jquery": "^3.7.1",
    "jszip": "^3.10.1",
    "marked": "^11.1.1",
    "pdfjs-dist": "^3.11.174",
    "qs": "^6.11.2",
    "tinycolor2": "^1.6.0",
    "txml": "^5.1.1",
    "v-viewer": "^3.0.13",
    "viewerjs": "^1.11.6",
    "vue": "^3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.2.0",
    "@types/d3": "^7.4.0",
    "@types/jquery": "^3.5.16",
    "@types/marked": "^4.0.8",
    "@types/node": "^18.14.2",
    "@types/qs": "^6.9.7",
    "@types/tinycolor2": "^1.4.3",
    "@vitejs/plugin-vue": "^4.0.0",
    "@vitejs/plugin-vue-jsx": "^3.0.0",
    "@vue/eslint-config-prettier": "^7.1.0",
    "@vue/eslint-config-typescript": "^11.0.2",
    "@vue/tsconfig": "^0.1.3",
    "eslint": "^8.34.0",
    "eslint-plugin-vue": "^9.9.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.8.4",
    "typescript": "^4.9.3",
    "vite": "^4.5.0",
    "vite-plugin-dts": "^3.6.4",
    "vue-tsc": "^1.8.24"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "license": "Apache-2.0"
}
