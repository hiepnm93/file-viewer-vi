{
  "name": "@flyfish-group/file-viewer3",
  "version": "1.0.5",
  "private": false,
  "type": "module",
  "description": "基于 Vue 3 + TypeScript + Vite 的纯前端多格式文件预览组件",
  "keywords": [
    "file-viewer",
    "vue3",
    "doc-preview"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "author": {
    "name": "Wangyu",
    "email": "wybaby168@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://git.flyfish.dev/flyfish-group/file-viewer.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check build-only",
    "build-lib": "run-p type-check build-lib-only",
    "preview": "vite preview",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "test:build": "vue-tsc --noEmit && vite build",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write src/",
    "build-lib-only": "vite build --mode lib",
    "test": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "main": "dist/index.umd.js",
  "module": "dist/index.mjs",
  "types": "dist/src/package/index.d.ts",
  "dependencies": {
    "axios": "^1.15.2",
    "billboard.js": "^3.18.0",
    "buffer": "^6.0.3",
    "d3": "^7.9.0",
    "dingbat-to-unicode": "^1.0.1",
    "docx-preview": "^0.3.7",
    "e-virt-table": "^1.3.25",
    "github-markdown-css": "^5.9.0",
    "jquery": "^4.0.0",
    "jszip": "^3.10.1",
    "marked": "^18.0.2",
    "msdoc-viewer": "^0.2.0",
    "pdfjs-dist": "^5.6.205",
    "qs": "^6.15.1",
    "styled-exceljs": "0.21.1",
    "tinycolor2": "^1.6.0",
    "v-viewer": "^3.0.23",
    "viewerjs": "^1.11.7",
    "vue": "^3.5.33"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.16.1",
    "@types/d3": "^7.4.3",
    "@types/jquery": "^4.0.0",
    "@types/node": "^25.6.0",
    "@types/qs": "^6.15.0",
    "@types/tinycolor2": "^1.4.6",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.1",
    "eslint-plugin-vue": "^10.9.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "sass": "^1.99.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vite-plugin-dts": "^4.5.4",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "license": "Apache-2.0"
}
