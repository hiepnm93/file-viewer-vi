{
  "name": "@flyfish-group/file-viewer-demo",
  "version": "1.0.23",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare-viewer": "node scripts/sync-viewer-assets.mjs",
    "dev": "pnpm --dir ../.. build:adapters && pnpm prepare-viewer && vite --host 127.0.0.1",
    "build": "pnpm --dir ../.. build:adapters && pnpm prepare-viewer && tsc -b tsconfig.json && vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@flyfish-group/file-viewer-react": "workspace:^1.0.23",
    "@flyfish-group/file-viewer-web": "workspace:^1.0.23",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
