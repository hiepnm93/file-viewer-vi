{
  "name": "@file-viewer/preset-all",
  "version": "2.0.11",
  "private": false,
  "type": "module",
  "description": "All renderer preset for Flyfish File Viewer, preserving the full format matrix while renderer packages are split out.",
  "keywords": [
    "file-viewer",
    "renderer-preset",
    "document-preview",
    "on-demand-renderer"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "author": {
    "name": "Wangyu",
    "email": "wybaby168@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flyfish-dev/file-viewer-preset-all.git",
    "directory": "packages/presets/all"
  },
  "homepage": "https://doc.file-viewer.app/guide/on-demand-renderers",
  "bugs": {
    "url": "https://github.com/flyfish-dev/file-viewer-preset-all/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "README.en.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "type-check": "tsc -b tsconfig.json"
  },
  "dependencies": {
    "@file-viewer/core": "workspace:^2.0.11"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "license": "Apache-2.0"
}
