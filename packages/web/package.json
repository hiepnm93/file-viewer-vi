{
  "name": "@flyfish-group/file-viewer-web",
  "version": "1.0.23",
  "private": false,
  "type": "module",
  "description": "Private-deploy pure web component for Flyfish Viewer",
  "keywords": [
    "file-viewer",
    "document-preview",
    "iframe",
    "vanilla-js",
    "web"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "author": {
    "name": "Wangyu",
    "email": "wybaby168@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flyfish-dev/file-viewer.git",
    "directory": "packages/web"
  },
  "homepage": "https://github.com/flyfish-dev/file-viewer",
  "bugs": {
    "url": "https://github.com/flyfish-dev/file-viewer/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "default": "./dist/node.js"
    },
    "./viewer/*": "./viewer/*",
    "./package.json": "./package.json"
  },
  "bin": {
    "file-viewer-copy-assets": "./scripts/copy-assets.mjs"
  },
  "files": [
    "dist",
    "scripts",
    "viewer",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "postinstall": "node ./scripts/copy-assets.mjs --postinstall",
    "type-check": "tsc -b tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "typescript": "^6.0.3"
  },
  "license": "Apache-2.0"
}
