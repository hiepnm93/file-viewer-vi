{
  "schemaVersion": 1,
  "organization": "flyfish-dev",
  "sourceBranch": "main",
  "corePackage": {
    "packageName": "@file-viewer/core",
    "visibility": "public-source",
    "repository": "file-viewer-core",
    "sourceRepository": "https://github.com/flyfish-dev/file-viewer-core",
    "github": "https://github.com/flyfish-dev/file-viewer-core",
    "gitee": "https://gitee.com/flyfish-dev/file-viewer-core",
    "aggregateRepository": "https://git.flyfish.dev/flyfish-group/file-viewer.git",
    "corePolicy": "framework-neutral-low-level-core-only",
    "note": "Core source is public. The private Gitea repository remains the complete aggregate workspace with release automation, integration history, and priority support for sponsors."
  },
  "renderers": [
    {
      "id": "pptx",
      "packageName": "@file-viewer/pptx",
      "packageDir": "packages/renderers/pptx",
      "repository": "pptxjs",
      "github": "https://github.com/flyfish-dev/pptxjs",
      "gitee": "https://gitee.com/flyfish-dev/pptxjs",
      "entryFormats": ["esm", "types", "worker"],
      "publicSource": true
    }
  ],
  "compatibilityPackages": [
    {
      "id": "vue3-compat-scoped",
      "packageName": "@flyfish-group/file-viewer3",
      "targetPackage": "@file-viewer/vue3",
      "packageDir": "packages/compat/vue3-scoped",
      "publicSource": false,
      "releaseArtifact": {
        "includeTarball": true
      }
    },
    {
      "id": "vue3-compat-unscoped",
      "packageName": "file-viewer3",
      "targetPackage": "@file-viewer/vue3",
      "packageDir": "packages/compat/vue3-unscoped",
      "publicSource": false,
      "releaseArtifact": {
        "includeTarball": false,
        "duplicateOf": "@flyfish-group/file-viewer3",
        "reason": "The open-source main repository keeps one Vue 3 compatibility tarball to avoid duplicate package bodies; the unscoped alias is still published to npm."
      }
    },
    {
      "id": "vue27-compat-scoped",
      "packageName": "@flyfish-group/file-viewer",
      "targetPackage": "@file-viewer/vue2.7",
      "packageDir": "packages/compat/vue2.7",
      "publicSource": false,
      "releaseArtifact": {
        "includeTarball": true
      }
    },
    {
      "id": "web-compat",
      "packageName": "@flyfish-group/file-viewer-web",
      "targetPackage": "@file-viewer/web",
      "packageDir": "packages/compat/web",
      "publicSource": false,
      "releaseArtifact": {
        "includeTarball": true
      }
    },
    {
      "id": "react-compat",
      "packageName": "@flyfish-group/file-viewer-react",
      "targetPackage": "@file-viewer/react",
      "packageDir": "packages/compat/react",
      "publicSource": false,
      "releaseArtifact": {
        "includeTarball": true
      }
    }
  ],
  "wrappers": [
    {
      "id": "vue3",
      "framework": "Vue 3",
      "packageName": "@file-viewer/vue3",
      "packageDir": "packages/components/vue3",
      "repository": "file-viewer-vue3",
      "github": "https://github.com/flyfish-dev/file-viewer-vue3",
      "gitee": "https://gitee.com/flyfish-dev/file-viewer-vue3",
      "entryFormats": ["esm", "types"],
      "historicalPackages": ["@flyfish-group/file-viewer3", "file-viewer3"]
    },
    {
      "id": "vue2.7",
      "framework": "Vue 2.7",
      "packageName": "@file-viewer/vue2.7",
      "packageDir": "packages/components/vue2.7",
      "repository": "file-viewer-vue2.7",
      "github": "https://github.com/flyfish-dev/file-viewer-vue2.7",
      "gitee": "https://gitee.com/flyfish-dev/file-viewer-vue2.7",
      "entryFormats": ["esm", "types"],
      "historicalPackages": ["@flyfish-group/file-viewer"]
    },
    {
      "id": "vue2.6",
      "framework": "Vue 2.6",
      "packageName": "@file-viewer/vue2.6",
      "packageDir": "packages/components/vue2.6",
      "repository": "file-viewer-vue2.6",
      "github": "https://github.com/flyfish-dev/file-viewer-vue2.6",
      "gitee": "https://gitee.com/flyfish-dev/file-viewer-vue2.6",
      "entryFormats": ["esm", "types"],
      "historicalPackages": []
    },
    {
      "id": "react",
      "framework": "React 18/19",
      "packageName": "@file-viewer/react",
      "packageDir": "packages/components/react",
      "repository": "file-viewer-react",
      "github": "https://github.com/flyfish-dev/file-viewer-react",
      "gitee": "https://gitee.com/flyfish-dev/file-viewer-react",
      "entryFormats": ["esm", "types"],
      "historicalPackages": ["@flyfish-group/file-viewer-react"]
    },
    {
      "id": "react-legacy",
      "framework": "React 16.8/17",
      "packageName": "@file-viewer/react-legacy",
      "packageDir": "packages/components/react-legacy",
      "repository": "file-viewer-react-legacy",
      "github": "https://github.com/flyfish-dev/file-viewer-react-legacy",
      "gitee": "https://gitee.com/flyfish-dev/file-viewer-react-legacy",
      "entryFormats": ["esm", "types"],
      "historicalPackages": []
    },
    {
      "id": "web",
      "framework": "Pure Web",
      "packageName": "@file-viewer/web",
      "packageDir": "packages/components/web",
      "repository": "file-viewer-web",
      "github": "https://github.com/flyfish-dev/file-viewer-web",
      "gitee": "https://gitee.com/flyfish-dev/file-viewer-web",
      "entryFormats": ["esm", "types", "iife", "viewer-assets", "copy-assets-cli"],
      "historicalPackages": ["@flyfish-group/file-viewer-web"]
    },
    {
      "id": "jquery",
      "framework": "jQuery",
      "packageName": "@file-viewer/jquery",
      "packageDir": "packages/components/jquery",
      "repository": "file-viewer-jquery",
      "github": "https://github.com/flyfish-dev/file-viewer-jquery",
      "gitee": "https://gitee.com/flyfish-dev/file-viewer-jquery",
      "entryFormats": ["esm", "types"],
      "historicalPackages": []
    },
    {
      "id": "svelte",
      "framework": "Svelte",
      "packageName": "@file-viewer/svelte",
      "packageDir": "packages/components/svelte",
      "repository": "file-viewer-svelte",
      "github": "https://github.com/flyfish-dev/file-viewer-svelte",
      "gitee": "https://gitee.com/flyfish-dev/file-viewer-svelte",
      "entryFormats": ["svelte-component", "esm", "types"],
      "historicalPackages": []
    }
  ]
}
