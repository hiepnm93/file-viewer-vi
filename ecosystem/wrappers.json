{
  "schemaVersion": 1,
  "organization": "flyfish-dev",
  "sourceBranch": "main",
  "corePackage": {
    "packageName": "@file-viewer/core",
    "description": "Framework-neutral TypeScript file preview core with format registry, lifecycle APIs, search, zoom, print, export, and renderer orchestration.",
    "visibility": "public-source",
    "repository": "file-viewer-core",
    "sourceRepository": "https://github.com/flyfish-dev/file-viewer-core",
    "github": "https://github.com/flyfish-dev/file-viewer-core",
    "gitee": "https://gitee.com/flyfish-dev/file-viewer-core",
    "aggregateRepository": "https://git.flyfish.dev/flyfish-group/file-viewer.git",
    "corePolicy": "framework-neutral-low-level-core-only",
    "note": "Core source is public. The private Gitea repository remains the complete aggregate workspace with release automation, integration history, and priority support for sponsors."
  },
  "renderers": [
    {
      "id": "pdf",
      "packageName": "@file-viewer/renderer-pdf",
      "description": "Standalone PDF renderer plugin for File Viewer with PDF.js page rendering, navigation, search, zoom, print, export, worker, CMap, WASM, and font asset support.",
      "packageDir": "packages/renderers/pdf",
      "repository": "file-viewer-renderer-pdf",
      "github": "https://github.com/flyfish-dev/file-viewer-renderer-pdf",
      "gitee": "https://gitee.com/flyfish-dev/file-viewer-renderer-pdf",
      "entryFormats": ["esm", "types"],
      "publicSource": true
    },
    {
      "id": "mindmap",
      "packageName": "@file-viewer/renderer-mindmap",
      "description": "Standalone XMind and mind map renderer plugin for File Viewer with modern/classic XMind parsing, draggable canvas, zoom, sheet navigation, and node outline support.",
      "packageDir": "packages/renderers/mindmap",
      "repository": "file-viewer-renderer-mindmap",
      "github": "https://github.com/flyfish-dev/file-viewer-renderer-mindmap",
      "gitee": "https://gitee.com/flyfish-dev/file-viewer-renderer-mindmap",
      "entryFormats": ["esm", "types"],
      "publicSource": true
    },
    {
      "id": "cad",
      "packageName": "@file-viewer/renderer-cad",
      "description": "Standalone CAD renderer plugin for File Viewer with DWG, DXF, DWF, DWFx, XPS, worker/WASM assets, layer controls, zoom, and native DWF rendering support.",
      "packageDir": "packages/renderers/cad",
      "repository": "file-viewer-renderer-cad",
      "github": "https://github.com/flyfish-dev/file-viewer-renderer-cad",
      "gitee": "https://gitee.com/flyfish-dev/file-viewer-renderer-cad",
      "entryFormats": ["esm", "types"],
      "publicSource": true
    },
    {
      "id": "typst",
      "packageName": "@file-viewer/renderer-typst",
      "description": "Standalone Typst renderer plugin for File Viewer with browser WASM compilation, paged SVG rendering, zoom, print, export, timeout, and offline WASM asset support.",
      "packageDir": "packages/renderers/typst",
      "repository": "file-viewer-renderer-typst",
      "github": "https://github.com/flyfish-dev/file-viewer-renderer-typst",
      "gitee": "https://gitee.com/flyfish-dev/file-viewer-renderer-typst",
      "entryFormats": ["esm", "types"],
      "publicSource": true
    },
    {
      "id": "pptx",
      "packageName": "@file-viewer/pptx",
      "description": "Native PPTX preview engine for File Viewer with worker-based PowerPoint parsing, slide rendering, themes, media, and charts.",
      "packageDir": "packages/renderers/pptx",
      "repository": "pptxjs",
      "github": "https://github.com/flyfish-dev/pptxjs",
      "gitee": "https://gitee.com/flyfish-dev/pptxjs",
      "entryFormats": ["esm", "types", "worker"],
      "publicSource": true
    }
  ],
  "presets": [
    {
      "id": "all",
      "packageName": "@file-viewer/preset-all",
      "description": "Full renderer preset for Flyfish File Viewer, preserving the complete format matrix while heavy renderers are split into standalone packages.",
      "packageDir": "packages/presets/all",
      "repository": "file-viewer-preset-all",
      "github": "https://github.com/flyfish-dev/file-viewer-preset-all",
      "gitee": "https://gitee.com/flyfish-dev/file-viewer-preset-all",
      "entryFormats": ["esm", "types"],
      "publicSource": true
    }
  ],
  "compatibilityPackages": [
    {
      "id": "vue3-compat-scoped",
      "packageName": "@flyfish-group/file-viewer3",
      "targetPackage": "@file-viewer/vue3",
      "packageDir": "packages/compat/vue3-scoped",
      "publicSource": false,
      "releaseArtifact": {
        "includeTarball": true
      }
    },
    {
      "id": "vue3-compat-unscoped",
      "packageName": "file-viewer3",
      "targetPackage": "@file-viewer/vue3",
      "packageDir": "packages/compat/vue3-unscoped",
      "publicSource": false,
      "releaseArtifact": {
        "includeTarball": false,
        "duplicateOf": "@flyfish-group/file-viewer3",
        "reason": "The open-source main repository keeps one Vue 3 compatibility tarball to avoid duplicate package bodies; the unscoped alias is still published to npm."
      }
    },
    {
      "id": "vue27-compat-scoped",
      "packageName": "@flyfish-group/file-viewer",
      "targetPackage": "@file-viewer/vue2.7",
      "packageDir": "packages/compat/vue2.7",
      "publicSource": false,
      "releaseArtifact": {
        "includeTarball": true
      }
    },
    {
      "id": "web-compat",
      "packageName": "@flyfish-group/file-viewer-web",
      "targetPackage": "@file-viewer/web",
      "packageDir": "packages/compat/web",
      "publicSource": false,
      "releaseArtifact": {
        "includeTarball": true
      }
    },
    {
      "id": "react-compat",
      "packageName": "@flyfish-group/file-viewer-react",
      "targetPackage": "@file-viewer/react",
      "packageDir": "packages/compat/react",
      "publicSource": false,
      "releaseArtifact": {
        "includeTarball": true
      }
    }
  ],
  "wrappers": [
    {
      "id": "web",
      "framework": "Vanilla JS / Pure Web",
      "packageName": "@file-viewer/web",
      "description": "Framework-free File Viewer package with Custom Element, ESM APIs, script-tag IIFE, worker/WASM viewer assets, and an asset copy CLI.",
      "packageDir": "packages/components/web",
      "repository": "file-viewer-web",
      "github": "https://github.com/flyfish-dev/file-viewer-web",
      "gitee": "https://gitee.com/flyfish-dev/file-viewer-web",
      "entryFormats": ["esm", "types", "iife", "viewer-assets", "copy-assets-cli"],
      "historicalPackages": ["@flyfish-group/file-viewer-web"]
    },
    {
      "id": "vue3",
      "framework": "Vue 3",
      "packageName": "@file-viewer/vue3",
      "description": "Production-ready Vue 3 file viewer component powered by @file-viewer/core, with toolbar, search, zoom, watermark, print, and export support.",
      "packageDir": "packages/components/vue3",
      "repository": "file-viewer-vue3",
      "github": "https://github.com/flyfish-dev/file-viewer-vue3",
      "gitee": "https://gitee.com/flyfish-dev/file-viewer-vue3",
      "entryFormats": ["esm", "types"],
      "historicalPackages": ["@flyfish-group/file-viewer3", "file-viewer3"]
    },
    {
      "id": "vue2.7",
      "framework": "Vue 2.7",
      "packageName": "@file-viewer/vue2.7",
      "description": "Production-ready Vue 2.7 file viewer component powered by @file-viewer/core for teams maintaining modern Vue 2 applications.",
      "packageDir": "packages/components/vue2.7",
      "repository": "file-viewer-vue2.7",
      "github": "https://github.com/flyfish-dev/file-viewer-vue2.7",
      "gitee": "https://gitee.com/flyfish-dev/file-viewer-vue2.7",
      "entryFormats": ["esm", "types"],
      "historicalPackages": ["@flyfish-group/file-viewer"]
    },
    {
      "id": "vue2.6",
      "framework": "Vue 2.6",
      "packageName": "@file-viewer/vue2.6",
      "description": "Production-ready Vue 2.6 file viewer component powered by @file-viewer/core for legacy Vue applications.",
      "packageDir": "packages/components/vue2.6",
      "repository": "file-viewer-vue2.6",
      "github": "https://github.com/flyfish-dev/file-viewer-vue2.6",
      "gitee": "https://gitee.com/flyfish-dev/file-viewer-vue2.6",
      "entryFormats": ["esm", "types"],
      "historicalPackages": []
    },
    {
      "id": "react",
      "framework": "React 18/19",
      "packageName": "@file-viewer/react",
      "description": "Production-ready React file viewer component powered by @file-viewer/core, with hooks, document actions, search, zoom, print, and export.",
      "packageDir": "packages/components/react",
      "repository": "file-viewer-react",
      "github": "https://github.com/flyfish-dev/file-viewer-react",
      "gitee": "https://gitee.com/flyfish-dev/file-viewer-react",
      "entryFormats": ["esm", "types"],
      "historicalPackages": ["@flyfish-group/file-viewer-react"]
    },
    {
      "id": "react-legacy",
      "framework": "React 16.8/17",
      "packageName": "@file-viewer/react-legacy",
      "description": "Production-ready React 16.8/17 file viewer component powered by @file-viewer/core for long-lived React applications.",
      "packageDir": "packages/components/react-legacy",
      "repository": "file-viewer-react-legacy",
      "github": "https://github.com/flyfish-dev/file-viewer-react-legacy",
      "gitee": "https://gitee.com/flyfish-dev/file-viewer-react-legacy",
      "entryFormats": ["esm", "types"],
      "historicalPackages": []
    },
    {
      "id": "jquery",
      "framework": "jQuery",
      "packageName": "@file-viewer/jquery",
      "description": "jQuery file viewer plugin powered by @file-viewer/core for legacy and mixed frontend stacks.",
      "packageDir": "packages/components/jquery",
      "repository": "file-viewer-jquery",
      "github": "https://github.com/flyfish-dev/file-viewer-jquery",
      "gitee": "https://gitee.com/flyfish-dev/file-viewer-jquery",
      "entryFormats": ["esm", "types"],
      "historicalPackages": []
    },
    {
      "id": "svelte",
      "framework": "Svelte",
      "packageName": "@file-viewer/svelte",
      "description": "Production-ready Svelte file viewer component powered by @file-viewer/core with the same viewer options and document actions.",
      "packageDir": "packages/components/svelte",
      "repository": "file-viewer-svelte",
      "github": "https://github.com/flyfish-dev/file-viewer-svelte",
      "gitee": "https://gitee.com/flyfish-dev/file-viewer-svelte",
      "entryFormats": ["svelte-component", "esm", "types"],
      "historicalPackages": []
    }
  ]
}
