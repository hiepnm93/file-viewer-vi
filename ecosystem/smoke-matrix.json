{
  "schemaVersion": 1,
  "description": "Migration smoke coverage matrix for preserving the Vue 3 baseline experience while moving renderer logic into the shared TypeScript core.",
  "coverage": {
    "requireAllRendererIds": true,
    "requiredFormatFamilies": [
      "pdf",
      "docx",
      "xlsx",
      "pptx",
      "ofd",
      "cad",
      "dwf",
      "dwfx",
      "epub",
      "archive",
      "email",
      "markdown",
      "code",
      "image",
      "audio",
      "video",
      "geo",
      "data-asset"
    ]
  },
  "surfaces": [
    "main-demo",
    "compare-page",
    "iframe",
    "script-tag",
    "vue3",
    "vue2.7",
    "vue2.6",
    "react",
    "react-legacy",
    "web",
    "jquery",
    "svelte"
  ],
  "wrappers": [
    {
      "id": "vue3",
      "packageName": "@file-viewer/vue3",
      "surface": "vue3"
    },
    {
      "id": "vue2.7",
      "packageName": "@file-viewer/vue2.7",
      "surface": "vue2.7"
    },
    {
      "id": "vue2.6",
