{
  "name": "file-viewer",
  "version": "1.0.12",
  "runtime": {
    "framework": "vue3",
    "viewerSite": "https://viewer.flyfish.dev",
    "docs": "https://doc.flyfish.dev"
  },
  "packages": {
    "vue3": "@flyfish-group/file-viewer3@1.0.12",
    "vue2": "@flyfish-group/file-viewer@1.0.12"
  },
  "features": [
    {
      "group": "document",
      "extensions": ["doc", "docx", "pdf", "ofd"],
      "lazyLoaded": true,
      "defaultScale": "fit-width"
    },
    {
      "group": "drawing",
      "extensions": ["dxf", "dwg", "excalidraw", "drawio", "dio"],
      "notes": ["DXF renders in browser", "DWG extracts embedded previews when possible", "Excalidraw uses @excalidraw/excalidraw", "draw.io uses diagrams.net GraphViewer"]
    },
    {
      "group": "model",
      "extensions": ["glb", "gltf", "obj", "stl", "ply", "fbx", "dae", "3ds", "3mf", "amf", "usd", "usda", "usdc", "usdz", "kmz", "pcd", "wrl", "vrml", "xyz", "vtk", "vtp", "step", "stp", "iges", "igs", "ifc", "3dm"],
      "renderer": "three.js",
      "lazyLoaded": true
    },
    {
      "group": "ebook",
      "extensions": ["epub", "umd"],
      "renderer": "epubjs-or-umd-parser",
      "lazyLoaded": true
    },
    {
      "group": "source",
      "extensions": ["js", "ts", "tsx", "vue", "json", "yaml", "sql"],
      "renderer": "highlight.js",
      "executeHtml": false
    }
  ],
  "qualityGate": {
    "typeCheck": true,
    "build": true,
    "browserSmoke": ["sample-picker", "code-preview", "pdf-toolbar"]
  },
  "updatedAt": "2026-05-22T10:20:00+08:00"
}
